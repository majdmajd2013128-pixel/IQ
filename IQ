<!DOCTYPE html>
<html lang="ar">
<head>
<meta charset="UTF-8">
<title>اختبار الذكاء العالمي</title>

<style>
body{
font-family:Arial;
text-align:center;
background:#f2f2f2;
}

.container{
background:white;
padding:25px;
margin:40px auto;
width:420px;
border-radius:10px;
box-shadow:0 0 10px gray;
}

button{
padding:10px 20px;
margin:8px;
border:none;
background:#3498db;
color:white;
border-radius:5px;
cursor:pointer;
}

button:hover{
background:#2980b9;
}

.leaderboard{
margin-top:20px;
text-align:left;
}
</style>

</head>

<body>

<div class="container">

<h2>اختبار الذكاء 🧠</h2>

<input id="playerName" placeholder="اكتب اسمك">

<div id="question"></div>

<div id="answers"></div>

<button onclick="nextQuestion()">السؤال التالي</button>

<h3 id="result"></h3>

<div class="leaderboard">
<h3>🏆 أفضل النتائج</h3>
<div id="leaderboard"></div>
</div>

</div>

<script>

let questions=[

{question:"كم يساوي 5 + 7 ؟",answers:["10","12","13"],correct:1},
{question:"ما الرقم التالي: 2 4 6 8 ؟",answers:["9","10","12"],correct:1},
{question:"كم يساوي 9 × 2 ؟",answers:["18","16","20"],correct:0},
{question:"كم يساوي 15 - 7 ؟",answers:["7","8","9"],correct:1},
{question:"ما الرقم التالي: 1 3 5 7 ؟",answers:["8","9","10"],correct:1},
{question:"كم يساوي 6 × 6 ؟",answers:["30","36","42"],correct:1},
{question:"كم يساوي 12 + 8 ؟",answers:["20","22","18"],correct:0},
{question:"كم يساوي 7 × 7 ؟",answers:["49","42","45"],correct:0},
{question:"كم يساوي 50 ÷ 5 ؟",answers:["10","15","20"],correct:0},
{question:"ما الرقم التالي: 3 6 9 12 ؟",answers:["14","15","16"],correct:1}

]

let current=0
let score=0

function showQuestion(){

document.getElementById("question").innerHTML=
questions[current].question

let answersHTML=""

for(let i=0;i<questions[current].answers.length;i++){

answersHTML+=
`<button onclick="checkAnswer(${i})">
${questions[current].answers[i]}
</button><br>`

}

document.getElementById("answers").innerHTML=answersHTML

}

function checkAnswer(i){

if(i===questions[current].correct){
score++
}

}

function nextQuestion(){

current++

if(current<questions.length){

showQuestion()

}
else{

let iq=70+(score*5)

document.getElementById("question").innerHTML="انتهى الاختبار"

document.getElementById("answers").innerHTML=""

document.getElementById("result").innerHTML=
"معدل الذكاء IQ: "+iq

saveScore(iq)

showLeaderboard()

}

}

function saveScore(iq){

let name=document.getElementById("playerName").value

if(name==""){
name="لاعب"
}

let scores=JSON.parse(localStorage.getItem("iqscores"))||[]

scores.push({name:name,iq:iq})

scores.sort((a,b)=>b.iq-a.iq)

scores=scores.slice(0,10)

localStorage.setItem("iqscores",JSON.stringify(scores))

}

function showLeaderboard(){

let scores=JSON.parse(localStorage.getItem("iqscores"))||[]

let html=""

scores.forEach((player,index)=>{

html+=
(index+1)+". "+player.name+" - IQ "+player.iq+"<br>"

})

document.getElementById("leaderboard").innerHTML=html

}

showQuestion()

showLeaderboard()

</script>

</body>
  </html>
